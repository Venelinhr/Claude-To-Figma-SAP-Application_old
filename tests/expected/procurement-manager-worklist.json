{
  "$schema": "https://claude-to-figma-sap/spec-schema.json",
  "meta": {
    "requirement": "As a procurement manager, I need to review and approve pending purchase orders. I need to see: PO number, supplier name, amount, and current status. I process about 20–30 per day and need to approve or reject items in bulk.",
    "floorplan": "worklist",
    "floorplanRationale": "Pre-scoped task queue of the user's own assigned approvals — not open-ended search. No FilterBar needed; the system already scopes the list by role.",
    "rationale": "Worklist with Responsive Table in MultiSelect mode for bulk approve/reject. ShellBar for navigation shell. ObjectStatus for semantic status visualization. IllustratedMessage for empty state when all items are processed.",
    "validationStatus": "pass",
    "unverifiedComponents": []
  },
  "screen": {
    "name": "Purchase Order Approvals — Worklist",
    "density": "compact",
    "theme": "sap_horizon",
    "viewport": "desktop"
  },
  "hierarchy": [
    {
      "id": "shell",
      "component": "ShellBar",
      "props": {
        "productName": "Purchase Orders",
        "showNotifications": true
      }
    },
    {
      "id": "page",
      "component": "DynamicPage",
      "props": {
        "fitContent": true
      },
      "slots": {
        "title": {
          "id": "page-title",
          "component": "DynamicPageTitle",
          "label": "My Purchase Order Approvals",
          "props": {
            "showVariantManagement": false
          }
        },
        "content": {
          "id": "po-table",
          "component": "Table",
          "props": {
            "mode": "MultiSelect",
            "growing": true,
            "growingScrollToLoad": true,
            "noDataText": "All done! No pending approvals."
          },
          "slots": {
            "headerToolbar": {
              "id": "table-toolbar",
              "component": "OverflowToolbar",
              "children": [
                {
                  "id": "table-title",
                  "component": "Title",
                  "label": "Purchase Orders (20)",
                  "props": { "level": "H3" }
                },
                {
                  "id": "toolbar-spacer",
                  "component": "ToolbarSpacer"
                },
                {
                  "id": "approve-btn",
                  "component": "Button",
                  "intent": "approval",
                  "label": "Approve"
                },
                {
                  "id": "reject-btn",
                  "component": "Button",
                  "intent": "destructive",
                  "label": "Reject"
                }
              ]
            },
            "columns": [
              { "id": "col-po", "component": "Column", "label": "PO Number" },
              { "id": "col-supplier", "component": "Column", "label": "Supplier" },
              { "id": "col-amount", "component": "Column", "label": "Amount" },
              { "id": "col-status", "component": "Column", "label": "Status" }
            ],
            "items": {
              "id": "row",
              "component": "ColumnListItem",
              "repeat": 5,
              "children": [
                {
                  "id": "po-id",
                  "component": "ObjectIdentifier",
                  "sampleData": {
                    "title": ["4500012345", "4500012346", "4500012347", "4500012348", "4500012349"],
                    "text": ["Office Supplies", "IT Equipment", "Maintenance", "Software Licenses", "Catering"]
                  }
                },
                {
                  "id": "supplier",
                  "component": "Text",
                  "sampleData": {
                    "text": ["Müller GmbH", "TechCorp AG", "SAP SE", "Delta Corp", "AlphaNet GmbH"]
                  }
                },
                {
                  "id": "amount",
                  "component": "ObjectNumber",
                  "sampleData": {
                    "number": ["1,250.00", "8,400.00", "3,100.00", "720.00", "15,800.00"],
                    "unit": "EUR"
                  }
                },
                {
                  "id": "status",
                  "component": "ObjectStatus",
                  "sampleData": {
                    "text": ["Pending", "Pending", "Pending", "Pending", "Pending"],
                    "state": ["Warning", "Warning", "Warning", "Warning", "Warning"]
                  }
                }
              ]
            }
          }
        }
      }
    }
  ]
}
