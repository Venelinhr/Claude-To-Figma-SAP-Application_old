      "requirement": "Message announced via aria-live=\"polite\"",
      "wcag": "4.1.3 (AA)"
    },
    {
      "category": "keyboard",
      "requirement": "Close button activatable via Enter/Space",
      "wcag": "2.1.1 (A)"
