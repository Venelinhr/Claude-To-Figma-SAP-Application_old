{
  "schemaVersion": "1.0.0",
  "id": "sap.m.SearchField",
  "name": "SearchField",
  "source": {
    "system": "sapui5",
    "ref": "https://ui5.sap.com/#/api/sap.m.SearchField"
  },
  "category": "form",
  "status": "stable",
  "description": "A search input field with search functionality.",
  "intentTags": [
    "search",
    "filter",
    "tier-a"
  ],
  "props": [
    {
      "name": "value",
      "type": {
        "kind": "string"
      },
      "required": false,
      "default": "",
      "constraints": [],
      "description": "The search value"
    },
    {
      "name": "placeholder",
      "type": {
        "kind": "string"
      },
      "required": false,
      "default": "",
      "constraints": [],
      "description": "Placeholder text"
    },
    {
      "name": "enabled",
      "type": {
        "kind": "boolean"
      },
      "required": false,
      "default": true,
      "constraints": [],
      "description": "Whether the search field is enabled"
    },
    {
      "name": "showSearchButton",
      "type": {
        "kind": "boolean"
      },
      "required": false,
      "default": true,
      "constraints": [],
      "description": "Whether to show the search button"
    },
    {
      "name": "showRefreshButton",
      "type": {
        "kind": "boolean"
      },
      "required": false,
      "default": false,
      "constraints": [],
      "description": "Whether to show the refresh button"
    }
  ],
  "events": [
    {
      "name": "search",
      "parameters": [
