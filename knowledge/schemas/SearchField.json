    {
      "name": "liveChange",
      "parameters": [
        {
          "name": "value",
          "type": {
            "kind": "string"
          },
          "description": "The new value"
        }
      ],
      "since": "1.0",
      "description": "Fired during value change"
    }
  ],
  "slots": [],
  "composition": {
    "allowedWith": [
      "sap.m.Toolbar",
      "sap.m.HBox",
      "sap.m.VBox",
      "sap.m.FlexBox",
      "sap.m.Page"
    ],
    "forbiddenWith": [],
    "notes": [
      "Use for search functionality",
      "Often placed in toolbars"
    ]
  },
  "tokens": {
    "semantic": {
      "color.border": "sapNeutralBorder",
      "color.text": "sapNeutralText",
