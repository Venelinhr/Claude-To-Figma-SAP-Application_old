{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Expected Output Schema for LLM-Ready Validation",
  "description": "The standardized schema that LLM outputs must follow for SAPUI5 LLM-Ready validation",
  "type": "object",
  "required": ["ui_tree", "sapui5", "meta"],
  "properties": {
    "ui_tree": {
      "type": "object",
      "description": "Hierarchical UI structure representation",
      "required": ["type", "props"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Component type (e.g., Page, Table, Button)"
        },
        "props": {
          "type": "object",
          "description": "Component properties"
        },
        "children": {
          "type": "array",
          "description": "Child components",
          "items": {
            "$ref": "#/properties/ui_tree"
          }
        }
      }
    },
    "sapui5": {
      "type": "object",
      "description": "SAPUI5-specific implementation details",
      "required": ["xml_view", "controller_js"],
      "properties": {
        "xml_view": {
          "type": "string",
          "description": "SAPUI5 XML view code"
        },
        "controller_js": {
          "type": "string",
          "description": "SAPUI5 controller JavaScript code"
        }
      }
    },
    "meta": {
      "type": "object",
      "description": "Metadata about the generation",
      "required": ["design_system_version", "model"],
      "properties": {
        "design_system_version": {
          "type": "string",
          "description": "Version of the design system used"
        },
        "model": {
          "type": "string",
          "description": "Name of the LLM model used"
        },
        "timestamp": {
          "type": "string",
          "description": "ISO 8601 timestamp of generation"
        }
      }
    }
  }
}
