{
  "schemaVersion": "1.0.0",
  "id": "sap.m.DatePicker",
  "name": "DatePicker",
  "source": {
    "system": "sapui5",
    "ref": "https://ui5.sap.com/#/api/sap.m.DatePicker"
  },
  "category": "form",
  "status": "stable",
  "description": "A date picker control for selecting dates.",
  "intentTags": [
    "date-input",
    "calendar",
    "tier-a"
  ],
  "props": [
    {
      "name": "value",
      "type": {
        "kind": "string"
      },
      "required": false,
      "default": "",
      "constraints": [],
      "description": "The date value"
    },
    {
      "name": "placeholder",
      "type": {
        "kind": "string"
      },
      "required": false,
      "default": "",
      "constraints": [],
      "description": "Placeholder text"
    },
    {
      "name": "displayFormat",
      "type": {
        "kind": "string"
      },
      "required": false,
      "default": "",
      "constraints": [],
      "description": "Date display format"
    },
    {
      "name": "enabled",
      "type": {
        "kind": "boolean"
      },
      "required": false,
      "default": true,
      "constraints": [],
