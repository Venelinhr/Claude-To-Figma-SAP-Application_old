  "tokens": {
    "semantic": {
      "color.border": "sapNeutralBorder",
      "color.text": "sapNeutralText",
      "spacing.2": "sapSpace2"
    },
    "componentOverrides": {}
  },
  "a11y": {
    "role": "",
    "nameFrom": [
      "label",
