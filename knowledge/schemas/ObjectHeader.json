      "Object information should be accessible"
    ]
  },
  "examples": [
    {
      "id": "objectheader-basic",
      "title": "Object Header",
      "kind": "minimal",
      "uiPlan": {
        "component": "sap.m.ObjectHeader",
        "props": {
