{
  "schemaVersion": "1.0.0",
  "id": "sap.m.ObjectHeader",
  "name": "ObjectHeader",
  "source": {
    "system": "sapui5",
    "ref": "https://ui5.sap.com/#/api/sap.m.ObjectHeader"
  },
  "category": "data",
  "status": "stable",
  "description": "An object header for displaying object information with title, subtitle, and attributes.",
  "intentTags": [
    "object-display",
    "header",
    "tier-a"
  ],
  "props": [
    {
      "name": "title",
      "type": {
        "kind": "string"
      },
      "required": false,
      "default": "",
      "constraints": [],
      "description": "The object title"
    },
    {
      "name": "intro",
      "type": {
        "kind": "string"
      },
      "required": false,
      "default": "",
      "constraints": [],
      "description": "The object intro text"
    },
    {
      "name": "number",
      "type": {
        "kind": "string"
      },
      "required": false,
      "default": "",
      "constraints": [],
      "description": "The object number"
    },
    {
      "name": "numberUnit",
      "type": {
        "kind": "string"
      },
      "required": false,
      "default": "",
      "constraints": [],
      "description": "The unit for the number"
    },
    {
      "name": "responsive",
      "type": {
        "kind": "boolean"
      },
      "required": false,
      "default": true,
      "constraints": [],
      "description": "Whether the header is responsive"
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "attributes",
      "cardinality": "0..n",
      "allowed": [
        "sap.m.ObjectAttribute"
      ],
      "description": "Object attributes",
      "since": "1.0"
    },
    {
      "name": "statuses",
      "cardinality": "0..n",
      "allowed": [
        "sap.m.ObjectStatus"
      ],
      "description": "Object statuses",
      "since": "1.0"
    }
  ],
  "composition": {
    "allowedWith": [
      "sap.m.Page",
      "sap.m.Panel",
      "sap.m.VBox"
    ],
    "forbiddenWith": [],
    "notes": [
      "Use for object details display",
      "Common in detail pages"
    ]
  },
  "tokens": {
    "semantic": {
      "color.text": "sapNeutralText",
      "spacing.3": "sapSpace3"
    },
    "componentOverrides": {}
  },
  "a11y": {
    "role": "",
    "nameFrom": [
      "title",
      "intro"
    ],
    "keyboard": [],
