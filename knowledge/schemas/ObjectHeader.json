          "intro": "Product ID: 12345"
        }
      },
      "whenToUse": [
        "For object details display",
        "In detail pages"
      ],
      "whenNotToUse": [
        "For simple headers (use Title)"
      ]
    }
  ],
  "versioning": {
    "since": "1.0",
    "deprecatedSince": null,
