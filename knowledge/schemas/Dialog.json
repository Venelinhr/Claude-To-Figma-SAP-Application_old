{
  "schemaVersion": "1.0.0",
  "id": "sap.m.Dialog",
  "name": "Dialog",
  "source": {
    "system": "sapui5",
    "ref": "https://ui5.sap.com/#/api/sap.m.Dialog"
  },
  "category": "feedback",
  "status": "stable",
  "description": "A modal dialog for displaying content and user interactions.",
  "intentTags": [
    "modal",
    "dialog",
    "tier-a"
  ],
  "props": [
    {
      "name": "title",
      "type": {
        "kind": "string"
      },
      "required": false,
      "default": "",
      "constraints": [],
      "description": "The dialog title"
    },
    {
      "name": "type",
      "type": {
        "kind": "enum",
        "enumValues": [
          "Message",
          "Standard",
          "None"
        ]
      },
      "required": false,
      "default": "Standard",
      "constraints": [],
      "description": "The dialog type"
    },
    {
      "name": "state",
      "type": {
        "kind": "enum",
        "enumValues": [
          "None",
          "Success",
          "Warning",
          "Error",
          "Information"
        ]
      },
      "required": false,
      "default": "None",
      "constraints": [],
      "description": "The dialog state"
    },
    {
      "name": "resizable",
      "type": {
        "kind": "boolean"
      },
      "required": false,
      "default": true,
      "constraints": [],
      "description": "Whether the dialog is resizable"
    },
    {
      "name": "draggable",
      "type": {
        "kind": "boolean"
      },
      "required": false,
      "default": true,
      "constraints": [],
      "description": "Whether the dialog is draggable"
    }
  ],
  "events": [
    {
      "name": "afterClose",
      "parameters": [],
      "since": "1.0",
      "description": "Fired after the dialog closes"
    },
    {
      "name": "beforeOpen",
      "parameters": [],
      "since": "1.0",
      "description": "Fired before the dialog opens"
    }
  ],
  "slots": [
    {
      "name": "content",
      "cardinality": "0..n",
      "allowed": [
        "sap.ui.core.Control"
      ],
      "description": "Dialog content",
      "since": "1.0"
    },
    {
      "name": "beginButton",
      "cardinality": "0..1",
      "allowed": [
        "sap.m.Button"
      ],
      "description": "Left button",
      "since": "1.0"
    },
    {
      "name": "endButton",
      "cardinality": "0..1",
      "allowed": [
        "sap.m.Button"
      ],
      "description": "Right button",
      "since": "1.0"
    }
  ],
  "composition": {
    "allowedWith": [
      "sap.m.Page",
      "sap.m.App"
    ],
    "forbiddenWith": [
      "sap.m.Dialog"
    ],
    "notes": [
      "Use for modal interactions",
      "Should have clear action buttons"
    ]
  },
  "tokens": {
    "semantic": {
      "color.bg": "sapNeutralBg",
      "spacing.3": "sapSpace3"
    },
    "componentOverrides": {}
  },
  "a11y": {
    "role": "dialog",
    "nameFrom": [
      "title"
    ],
    "keyboard": [
      "Escape"
    ],
    "notes": [
      "Dialog should be trap focus",
      "Escape key should close dialog"
    ]
  },
  "examples": [
    {
      "id": "dialog-basic",
      "title": "Modal Dialog",
      "kind": "minimal",
      "uiPlan": {
        "component": "sap.m.Dialog",
        "props": {
          "title": "Confirmation",
          "type": "Message"
        }
      },
      "whenToUse": [
        "For confirmations",
        "For forms in modal",
        "For important messages"
      ],
      "whenNotToUse": [
        "For inline content"
      ]
    }
  ],
  "versioning": {
    "since": "1.0",
    "deprecatedSince": null,
    "ui5Version": "1.0"
  }
}
