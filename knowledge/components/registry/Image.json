  "accessibilityRules": [
    {
      "category": "labeling",
      "requirement": "Provide `alt` text unless the image is purely decorative (`decorative: true`)"
    },
    {
      "category": "contrast",
      "requirement": "If the image conveys information, ensure sufficient contrast against surrounding background"
    }
  ],
  "doRules": [
    "Set decorative:true when the image is purely visual and alt would be redundant",
    "Provide meaningful alt text for informational images",
    "Constrain via width/height props; do not rely on parent auto-layout alone"
  ],
  "dontRules": [
    "Do not use Image where an Icon is appropriate — icons scale better and support tokens",
    "Do not stretch an Image beyond native aspect ratio",
    "Do not use Image inside table cells for icons — use IconButton"
  ],
  "compatibleComponents": [
