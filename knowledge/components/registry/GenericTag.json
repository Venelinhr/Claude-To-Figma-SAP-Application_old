{
  "componentName": "GenericTag",
  "figmaCommunityId": "sap-web-ui-kit",
  "figmaComponentId": "alias:Tag",
  "figmaLibraryFileId": "p7zm5EMBk5DRRZdxNeJ4f5",
  "componentCategory": "Display",
  "supportedVariants": [
    { "property": "Design",   "ui5Property": "design",   "values": ["Full","StatusIconHidden"], "default": "Full" },
    { "property": "Status",   "ui5Property": "status",   "values": ["None","Success","Warning","Error","Information"], "default": "None" },
    { "property": "ValueState","ui5Property": "valueState","values": ["None","Success","Warning","Error","Information"], "default": "None" }
  ],
  "supportedProperties": [
    { "name": "text",   "ui5Name": "text",   "type": "string", "exposedInLibrary": true, "default": "" },
    { "name": "status", "ui5Name": "status", "type": "string", "exposedInLibrary": true, "default": "None" },
    { "name": "value",  "ui5Name": "value",  "type": "ObjectNumber", "exposedInLibrary": false, "default": null }
  ],
  "supportedStates": ["None","Success","Warning","Error","Information"],
  "typographyRules": [
    { "role": "text",  "fontFamily": "72", "fontStyle": "Regular", "fontSize": 14, "sapStyleName": "MediumText/LHAuto/Regular" },
    { "role": "value", "fontFamily": "72", "fontStyle": "Bold",    "fontSize": 14, "sapStyleName": "MediumText/LHAuto/Bold" }
  ],
  "colorTokenRules": [
    { "role": "background",         "token": "sapContent_Container_Background", "fallbackHex": "#FFFFFF" },
    { "role": "border",             "token": "sapContent_Container_BorderColor","fallbackHex": "#D5DADE" },
    { "role": "status-icon-success","token": "sapPositiveElementColor","fallbackHex": "#256F3A" },
    { "role": "status-icon-warning","token": "sapCriticalElementColor","fallbackHex": "#B87E00" },
    { "role": "status-icon-error",  "token": "sapNegativeElementColor","fallbackHex": "#B00" },
    { "role": "status-icon-info",   "token": "sapInformativeElementColor","fallbackHex": "#0070F2" }
  ],
  "accessibilityRules": [
    { "category": "labeling", "requirement": "The status icon must not be the sole conveyor of state — pair with text" },
    { "category": "contrast", "requirement": "Text and status icon ≥ 4.5:1 against the tag background" }
  ],
  "doRules": [
    "Use for compact composite KPI badges (label + numeric value + status icon)",
    "Bind status to the value semantics (over-budget→Error, on-target→Success)",
    "Prefer GenericTag over ObjectStatus when a numeric value is present alongside the label"
  ],
  "dontRules": [
    "Do not use for pure interactive filter chips — use Token",
    "Do not use for status-only display — use ObjectStatus",
    "Do not stack more than 3 GenericTags side by side"
  ],
  "compatibleComponents": ["DynamicPageTitle","DynamicPageHeader","ObjectPageHeader","Card","Panel","Toolbar","OverflowToolbar","ObjectListItem","ColumnListItem","StandardListItem"],
  "incompatiblePatterns": ["Inside ShellBar","Inside Dialog footer"],
  "guidelineUrl": "https://experience.sap.com/fiori-design-web/generic-tag/",
  "demoKitUrl": "https://sapui5.hana.ondemand.com/#/entity/sap.m.GenericTag",
  "apiUrl": "https://sapui5.hana.ondemand.com/#/api/sap.m.GenericTag",
  "sampleUrls": [],
  "libraryVersion": "1.149.0",
  "lastValidated": "2026-07-07",
  "pluginNotes": {
    "textInjectionMethod": "setProperties",
    "sizingConstraints": "Auto width to hug content. Height ~24px compact, ~32px cozy.",
    "knownIssues": [
      "SAP Web UI Kit doesn't ship a dedicated 'Generic Tag' component — the visual pattern is a variant of the Tag component. Plugin aliases GenericTag → Tag."
    ]
  },
  "composition": {
    "validParents": ["DynamicPageTitle","DynamicPageHeader","ObjectPageHeader","Card","Panel","Toolbar","OverflowToolbar","ObjectListItem","ColumnListItem","StandardListItem","Dialog","Popover","SapTableRow"],
    "topLevelOnly": false,
    "validChildren": [],
    "mustInclude": [],
    "mustExclude": [],
    "commonSiblings": ["Title","Text","ObjectStatus","Tag","ObjectNumber"]
  }
}
