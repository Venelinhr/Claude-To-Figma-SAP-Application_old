    {
      "name": "showTitle",
      "ui5Name": "showTitle",
      "type": "boolean",
      "exposedInLibrary": false,
      "default": false
    }
  ],
  "supportedStates": [
    "Regular",
    "Hover",
    "Focused",
    "Disabled"
  ],
  "typographyRules": [
    {
      "role": "item-text",
      "fontFamily": "72",
      "fontStyle": "Regular",
      "fontSize": 14,
      "sapStyleName": "MediumText/LHAuto/Regular"
    }
  ],
  "colorTokenRules": [
    {
      "role": "background",
      "token": "sapContent_Container_Background",
      "fallbackHex": "#FFFFFF"
    },
    {
      "role": "border",
      "token": "sapContent_Container_BorderColor",
      "fallbackHex": "#D5DADE"
    },
    {
      "role": "item-hover-bg",
      "token": "sapList_Hover_Background",
      "fallbackHex": "#F5F6F7"
    }
  ],
  "accessibilityRules": [
    {
      "category": "keyboard",
      "requirement": "Arrow keys navigate; Enter selects; Escape closes"
    },
    {
      "category": "focus",
      "requirement": "First item receives focus on open"
    }
  ],
  "doRules": [
    "Use as a popup menu opened by a MenuButton, SplitButton, IconMenuButton, or right-click context",
    "Items are MenuListItem components (supports icon, text, submenu-arrow)",
    "Also usable as a Submenu — overlaps parent Menu by 4px per SAP guidance"
  ],
  "dontRules": [
    "Do not use for permanent navigation — use List or SideNavigation",
    "Do not use for form input — use Select or ComboBox",
    "Do not nest more than 2 submenu levels — becomes hard to navigate"
  ],
  "compatibleComponents": [
    "MenuButton",
    "SplitButton",
    "IconMenuButton",
    "MenuListItem"
  ],
  "incompatiblePatterns": [
    "Inside a Dialog content area as a permanent list — use List instead"
  ],
  "guidelineUrl": "https://experience.sap.com/fiori-design-web/menu/",
  "demoKitUrl": "https://sapui5.hana.ondemand.com/#/entity/sap.m.Menu",
