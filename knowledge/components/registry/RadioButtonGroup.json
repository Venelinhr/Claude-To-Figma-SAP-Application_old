      "type": "text",
      "exposedInLibrary": true,
      "default": ""
    }
  ],
  "supportedStates": [
    "Regular",
    "Hover",
    "Focused",
    "Active",
    "Disabled"
  ],
  "typographyRules": [
    {
      "role": "default",
      "fontFamily": "72",
      "fontStyle": "Regular",
      "fontSize": 14,
      "sapStyleName": "MediumText/LHAuto/Regular"
    }
  ],
  "colorTokenRules": [
    {
      "role": "border",
      "state": "Default",
      "token": "sapField_BorderColor",
      "fallbackHex": "#556B81"
    },
    {
      "role": "selected-fill",
      "state": "Selected",
      "token": "sapButton_Emphasized_Background",
