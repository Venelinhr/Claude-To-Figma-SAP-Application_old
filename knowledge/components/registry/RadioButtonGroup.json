  "libraryVersion": "2025.06",
  "lastValidated": "2026-06-27",
  "pluginNotes": "RadioButtonGroup is composed (no single Figma instance). Plugin builds VERTICAL Auto Layout containing N RadioButton instances. Spec emits { component:\"RadioButtonGroup\", props:{ items:[{label,selected?}] } }.",
