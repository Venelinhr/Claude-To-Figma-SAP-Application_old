      "fallbackHex": "#1D2D3E"
    }
  ],
  "accessibilityRules": [
    {
      "category": "contrast",
      "requirement": "Text contrast \u2265 4.5:1 against bg (WCAG AA)",
      "wcag": "1.4.3"
    },
    {
      "category": "tap-target",
      "requirement": "Min 32\u00d732 Compact / 44\u00d744 Cozy"
    },
    {
      "category": "keyboard",
      "requirement": "Fully operable via keyboard"
    },
    {
      "category": "focus",
      "requirement": "Visible focus indicator"
    }
  ],
  "doRules": [
    "Show all options at once",
    "Mark exactly one as selected",
    "Provide clear, distinct labels",
    "Use vertical layout for >3 options"
  ],
  "dontRules": [
    "Do not allow zero-selected state when a default is reasonable",
    "Do not exceed 7 options",
    "Do not use RadioButtonGroup for binary toggles (use Switch)"
  ],
  "compatibleComponents": [
