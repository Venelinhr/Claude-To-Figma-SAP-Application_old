  "typographyRules": [
    {
      "role": "brand",
      "fontFamily": "72",
      "fontStyle": "Semibold",
      "fontSize": 16,
      "sapStyleName": "App Headers/Brand"
    }
  ],
  "colorTokenRules": [
    {
      "role": "background",
      "token": "sapShell_Background",
      "fallbackHex": "#FFFFFF"
    },
    {
      "role": "text",
      "token": "sapShell_TextColor",
      "fallbackHex": "#1D2D3E"
    },
    {
      "role": "border",
      "token": "sapShell_BorderColor",
      "fallbackHex": "#EAECEE"
    }
  ],
  "accessibilityRules": [
    {
      "category": "contrast",
      "requirement": "Brand text contrast ≥ 4.5:1 against shell background",
      "wcag": "1.4.3"
    },
    {
      "category": "labeling",
      "requirement": "All shell icon buttons MUST have tooltips"
    },
    {
      "category": "keyboard",
      "requirement": "Tab order: hamburger → brand → middle area → right area → avatar"
    },
    {
      "category": "focus",
      "requirement": "Visible focus indicator on every interactive shell element"
    }
  ],
  "doRules": [
    "Place ShellBar as the first node in screen hierarchy",
    "Use Branding Button slot for product name (max 2 lines)",
    "Show only icons users need — hide others via boolean variants",
    "Keep ShellBar height fixed at 52px regardless of variant"
  ],
  "dontRules": [
    "Do not place ShellBar inside another container with padding",
    "Do not add custom buttons outside the supported slots",
    "Do not change ShellBar background color — it is locked to sapShellColor"
  ],
  "compatibleComponents": [
    "Avatar",
    "Shell Search",
    "Shell Icon Button",
    "Branding Button",
    "User Menu"
  ],
  "incompatiblePatterns": [
    "Inside a page-level container — must be top-level",
    "Stacked with another shell-like header"
  ],
  "guidelineUrl": "https://experience.sap.com/fiori-design-web/shell-bar/",
  "demoKitUrl": "https://sapui5.hana.ondemand.com/#/entity/sap.f.ShellBar",
