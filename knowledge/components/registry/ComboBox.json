{
  "componentName": "ComboBox",
  "figmaCommunityId": "sap-web-ui-kit",
  "figmaComponentId": "alias:Select",
  "figmaLibraryFileId": "p7zm5EMBk5DRRZdxNeJ4f5",
  "componentCategory": "Input",
  "supportedVariants": [
    { "property": "Form Factor",       "values": ["Compact","Cozy"], "default": "Compact" },
    { "property": "Interaction State", "values": ["Regular","Hover","Focused","Active","Disabled","Readonly","Error","Warning","Information","Success"], "default": "Regular" }
  ],
  "supportedProperties": [
    { "name": "value",       "ui5Name": "value",       "type": "string",  "exposedInLibrary": true,  "default": "" },
    { "name": "placeholder", "ui5Name": "placeholder", "type": "string",  "exposedInLibrary": true,  "default": "" },
    { "name": "editable",    "ui5Name": "editable",    "type": "boolean", "exposedInLibrary": false, "default": true },
    { "name": "showButton",  "ui5Name": "showButton",  "type": "boolean", "exposedInLibrary": false, "default": true }
  ],
  "supportedStates": ["Regular","Hover","Focused","Active","Disabled","Error","Warning","Information","Success"],
  "typographyRules": [
    { "role": "value",       "fontFamily": "72", "fontStyle": "Regular", "fontSize": 14, "sapStyleName": "MediumText/LHAuto/Regular" },
    { "role": "placeholder", "fontFamily": "72", "fontStyle": "Regular", "fontSize": 14, "sapStyleName": "MediumText/LHAuto/Regular" }
  ],
  "colorTokenRules": [
    { "role": "field-background",  "token": "sapField_Background",        "fallbackHex": "#FFFFFF" },
    { "role": "field-border",      "token": "sapField_BorderColor",       "fallbackHex": "#556B81" },
    { "role": "field-focus",       "token": "sapField_FocusColor",        "fallbackHex": "#0064D9" },
    { "role": "value-text",        "token": "sapField_TextColor",         "fallbackHex": "#1A2733" },
    { "role": "placeholder-text",  "token": "sapField_PlaceholderTextColor", "fallbackHex": "#67707E" }
  ],
  "accessibilityRules": [
    { "category": "labeling",  "requirement": "Associate a Label via labelFor" },
    { "category": "keyboard",  "requirement": "Arrow keys open list; typing filters items" },
    { "category": "focus",     "requirement": "Visible focus indicator using sapField_FocusColor" }
  ],
  "doRules": [
    "Use ComboBox when the user picks ONE value from a known list AND may need to type-ahead / free-form entry",
    "Provide a placeholder to hint the expected value",
    "Prefer Select when strict single-choice with no free entry"
  ],
  "dontRules": [
    "Do not use for multi-select — use MultiComboBox",
    "Do not use for date/time — use DatePicker / TimePicker",
    "Do not overload with 200+ items — use a MultiInput with Suggestions or a Value Help Dialog"
  ],
  "compatibleComponents": ["Label","Form","SimpleForm","FormElement","FilterBar","Toolbar","OverflowToolbar","Panel","Dialog","Popover"],
  "incompatiblePatterns": ["Inside ShellBar","Inside table cells"],
  "guidelineUrl": "https://experience.sap.com/fiori-design-web/combo-box/",
  "demoKitUrl": "https://sapui5.hana.ondemand.com/#/entity/sap.m.ComboBox",
  "apiUrl": "https://sapui5.hana.ondemand.com/#/api/sap.m.ComboBox",
  "sampleUrls": [],
  "libraryVersion": "1.149.0",
  "lastValidated": "2026-07-07",
  "pluginNotes": {
    "textInjectionMethod": "setProperties",
    "sizingConstraints": "Same as Select. Min 120px useful width; grows to fill parent by default.",
    "knownIssues": [
      "SAP Web UI Kit explicitly directs 'If you want to use the Combobox please use the Select component.' The plugin aliases ComboBox → Select. Same visual rendering."
    ]
  },
  "composition": {
    "validParents": ["Form","SimpleForm","FormContainer","FormElement","FilterBar","Toolbar","OverflowToolbar","Panel","Card","Dialog","Popover","SapFormSection"],
    "topLevelOnly": false,
    "validChildren": [],
    "mustInclude": [],
    "mustExclude": [],
    "commonSiblings": ["Label","Input","Select","MultiComboBox"]
  }
}
