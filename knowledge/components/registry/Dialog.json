  "accessibilityRules": [
    {
      "category": "keyboard",
      "requirement": "Escape closes; Tab cycles within dialog (focus trap)"
    },
    {
      "category": "focus",
      "requirement": "Focus moves into dialog on open; returns to trigger on close"
    },
    {
      "category": "labeling",
      "requirement": "Dialog has accessible title"
    },
    {
      "category": "status",
      "requirement": "Destructive dialogs use State=Warning or Error with text — not color alone"
    }
  ],
  "doRules": [
    "Use for confirmations, focused tasks, or detail views requiring user action",
    "Include primary action button (right) and Cancel (left)",
    "Use State variant for semantic messages"
  ],
  "dontRules": [
    "Do not stack dialogs",
    "Do not put long forms in Dialog — use a new page",
    "Do not omit close affordance"
  ],
