  "doRules": [
    "Use List for ~3–20 items with consistent structure",
    "Show title + optional description per item",
    "Use MultiSelect mode for bulk actions"
  ],
  "dontRules": [
    "Do not use List for tabular data with multiple aligned columns — use Table",
    "Do not put unrelated content types in one list"
  ],
