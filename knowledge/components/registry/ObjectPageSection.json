{
  "componentName": "ObjectPageSection",
  "figmaCommunityId": "sap-web-ui-kit",
  "figmaComponentId": "alias:Panel",
  "figmaLibraryFileId": "p7zm5EMBk5DRRZdxNeJ4f5",
  "componentCategory": "Page Layout",
  "supportedVariants": [
    {
      "property": "Form Factor",
      "values": [
        "Compact",
