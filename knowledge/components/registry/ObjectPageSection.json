    },
    {
      "category": "tap-target",
      "requirement": "Min 32×32 Compact / 44×44 Cozy"
    },
    {
      "category": "keyboard",
      "requirement": "Fully operable via keyboard"
    },
    {
      "category": "focus",
      "requirement": "Visible focus indicator"
    }
  ],
  "doRules": [
    "Provide a clear, scoped title",
    "Use 2-7 SubSections per Section",
    "Make title navigable via the page anchor menu"
  ],
  "dontRules": [
    "Do not nest Sections",
    "Do not exceed 7 SubSections per Section",
    "Do not omit the title"
  ],
  "compatibleComponents": [
    "ObjectPageLayout"
  ],
  "incompatiblePatterns": [
    "See doRules and dontRules for context-specific rules."
