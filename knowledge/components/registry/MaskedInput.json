{
  "componentName": "MaskedInput",
  "figmaCommunityId": "sap-web-ui-kit",
  "figmaComponentId": "alias:Input",
  "figmaLibraryFileId": "p7zm5EMBk5DRRZdxNeJ4f5",
  "componentCategory": "Input",
  "supportedVariants": [
    {
      "property": "Form Factor",
      "values": [
        "Compact",
        "Cozy"
      ],
      "default": "Compact"
    },
    {
      "property": "Interaction State",
      "values": [
        "Regular",
        "Hover",
        "Focused",
        "Active",
        "Disabled"
      ],
      "default": "Regular"
    }
  ],
  "supportedProperties": [
    {
      "name": "text",
      "ui5Name": "text",
      "type": "text",
      "exposedInLibrary": true,
      "default": ""
    }
  ],
  "supportedStates": [
    "Regular",
    "Hover",
    "Focused",
    "Active",
    "Disabled"
  ],
  "typographyRules": [
    {
      "role": "default",
      "fontFamily": "72",
      "fontStyle": "Regular",
      "fontSize": 14,
      "sapStyleName": "MediumText/LHAuto/Regular"
    }
  ],
  "colorTokenRules": [
    {
      "role": "text",
      "state": "Default",
      "token": "sapList_TextColor",
      "fallbackHex": "#1D2D3E"
    },
    {
      "role": "placeholder",
      "state": "Default",
      "token": "sapField_PlaceholderTextColor",
      "fallbackHex": "#556B82"
    },
    {
      "role": "border",
      "state": "Default",
      "token": "sapField_BorderColor",
      "fallbackHex": "#556B81"
    }
  ],
  "accessibilityRules": [
    {
      "category": "contrast",
      "requirement": "Text contrast \u2265 4.5:1 against bg (WCAG AA)",
      "wcag": "1.4.3"
    },
    {
      "category": "tap-target",
      "requirement": "Min 32\u00d732 Compact / 44\u00d744 Cozy"
    },
    {
      "category": "keyboard",
      "requirement": "Fully operable via keyboard"
    },
    {
      "category": "focus",
      "requirement": "Visible focus indicator"
    }
  ],
  "doRules": [
    "Provide a clear placeholder showing the mask format",
    "Use the correct mask character (9 for digit, A for letter, etc.)",
    "Validate completeness before submit"
  ],
  "dontRules": [
    "Do not use MaskedInput for variable-length data",
    "Do not omit the mask placeholder",
    "Do not localize without re-checking mask format"
  ],
  "compatibleComponents": [
    "Form",
    "Dialog",
    "Panel"
  ],
  "incompatiblePatterns": [
    "See doRules and dontRules for context-specific rules."
  ],
  "guidelineUrl": "https://experience.sap.com/fiori-design-web/masked-input/",
  "demoKitUrl": "https://sdk.openui5.org/entity/sap.m.MaskedInput",
  "apiUrl": "https://sdk.openui5.org/api/sap.m.MaskedInput",
  "sampleUrls": [
    "https://sdk.openui5.org/entity/sap.m.MaskedInput/sample/sap.m.sample.MaskedInput"
  ],
  "libraryVersion": "2025.06",
  "lastValidated": "2026-06-27",
  "pluginNotes": "MaskedInput is sap.m.MaskedInput. Plugin renders as Input instance with placeholder showing the mask format. Mask enforcement is runtime-only \u2014 Figma renders the visual.",
  "composition": {
    "validParents": [
