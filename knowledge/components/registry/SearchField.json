  "accessibilityRules": [
    {
      "category": "labeling",
      "requirement": "SearchField MUST have an accessible name via aria-label or associated <label>",
      "wcag": "4.1.2, 3.3.2"
    },
    {
      "category": "tap-target",
      "requirement": "Min 32\u00d732 (Compact) / 44\u00d744 (Cozy)"
    },
    {
      "category": "focus",
      "requirement": "Visible focus indicator on keyboard navigation"
    },
    {
      "category": "contrast",
      "requirement": "Border \u2265 3:1 with background (WCAG AA non-text)",
      "wcag": "1.4.11"
    }
  ],
  "doRules": [
    "Use SearchField in OverflowToolbar at the right of the toolbar, before action buttons",
    "Provide a meaningful placeholder (e.g. 'Filter Artifacts', 'Search Invoices')",
    "Enable showSearchButton when search is the primary action; disable on instant filter",
    "Bind border to sapField_BorderColor and placeholder to sapField_PlaceholderTextColor"
  ],
  "dontRules": [
    "Do not use SearchField as a generic text input \u2014 use Input instead",
    "Do not use vague placeholders like 'Search' alone; specify what is searched",
    "Do not stack multiple SearchFields in one toolbar",
    "Do not omit the magnifier icon \u2014 it is the visual signal that this is search"
  ],
  "compatibleComponents": [
    "OverflowToolbar",
    "DynamicPageTitle",
    "FilterBar"
  ],
  "incompatiblePatterns": [
    "Inside table cells \u2014 use Input instead",
    "Inside Dialog footer \u2014 use Input"
  ],
  "guidelineUrl": "https://experience.sap.com/fiori-design-web/search-field/",
  "demoKitUrl": "https://sdk.openui5.org/entity/sap.m.SearchField",
