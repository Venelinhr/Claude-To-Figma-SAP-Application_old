  "accessibilityRules": [
    {
      "category": "labeling",
      "requirement": "Associate a Label describing what is being rated"
    },
    {
      "category": "keyboard",
      "requirement": "Arrow keys increment/decrement rating when editable"
    }
  ],
  "doRules": [
    "Use for user-facing ratings on a 5-star scale by default",
    "Bind to a Label describing what is being rated (skill, feedback, quality)",
    "Set displayOnly:true when the rating is informational (e.g. inside a table row)"
  ],
  "dontRules": [
    "Do not use for numeric input — use StepInput or Slider",
    "Do not exceed 5 stars — accessibility becomes fragile at higher counts",
    "Do not use in Toolbar — space-inefficient"
  ],
  "compatibleComponents": [
