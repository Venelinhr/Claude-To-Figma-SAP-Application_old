{
  "componentName": "FormContainer",
  "figmaCommunityId": "sap-web-ui-kit",
  "figmaComponentId": "alias:Form",
  "figmaLibraryFileId": "p7zm5EMBk5DRRZdxNeJ4f5",
  "componentCategory": "Forms",
  "supportedVariants": [
    {
      "property": "Form Factor",
      "values": [
        "Compact",
        "Cozy"
      ],
      "default": "Compact"
    },
    {
      "property": "Interaction State",
      "values": [
        "Regular",
        "Hover",
        "Focused",
        "Active",
        "Disabled"
      ],
      "default": "Regular"
    }
  ],
  "supportedProperties": [
    {
      "name": "text",
      "ui5Name": "text",
      "type": "text",
      "exposedInLibrary": true,
      "default": ""
    }
  ],
  "supportedStates": [
    "Regular",
    "Hover",
    "Focused",
    "Active",
    "Disabled"
  ],
  "typographyRules": [
    {
      "role": "default",
      "fontFamily": "72",
      "fontStyle": "Regular",
      "fontSize": 14,
      "sapStyleName": "MediumText/LHAuto/Regular"
    }
  ],
  "colorTokenRules": [
    {
      "role": "title",
      "state": "Default",
      "token": "sapTitleColor",
      "fallbackHex": "#1D2D3E"
    }
  ],
  "accessibilityRules": [
    {
      "category": "contrast",
      "requirement": "Text contrast ≥ 4.5:1 against bg (WCAG AA)",
      "wcag": "1.4.3"
    },
    {
      "category": "tap-target",
      "requirement": "Min 32×32 Compact / 44×44 Cozy"
    },
    {
      "category": "keyboard",
      "requirement": "Fully operable via keyboard"
    },
    {
      "category": "focus",
      "requirement": "Visible focus indicator"
    }
  ],
  "doRules": [
    "Provide a clear group title when appropriate",
    "Group 3-7 FormElements per FormContainer",
    "Use sentence-case titles"
  ],
  "dontRules": [
    "Do not nest FormContainer",
    "Do not exceed 7 FormElements per group"
  ],
  "compatibleComponents": [
    "Form",
    "SimpleForm"
  ],
  "incompatiblePatterns": [
    "See doRules and dontRules for context-specific rules."
  ],
  "guidelineUrl": "https://experience.sap.com/fiori-design-web/form-container/",
  "demoKitUrl": "https://sdk.openui5.org/entity/sap.m.FormContainer",
  "apiUrl": "https://sdk.openui5.org/api/sap.m.FormContainer",
  "sampleUrls": [
    "https://sdk.openui5.org/entity/sap.m.FormContainer/sample/sap.m.sample.FormContainer"
  ],
  "libraryVersion": "2025.06",
  "lastValidated": "2026-06-27",
  "pluginNotes": "FormContainer is part of Form composition. Plugin renders as a vertical AutoLayout group with optional H3 title.",
  "composition": {
    "validParents": [
      "Form",
      "SimpleForm",
      "Panel",
      "Dialog"
    ],
    "topLevelOnly": false,
    "validChildren": [
