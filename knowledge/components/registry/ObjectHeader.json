    "InfoLabel"
  ],
  "incompatiblePatterns": [
    "Inside ShellBar",
    "Inside DynamicPage (use DynamicPageHeader instead)",
    "Inside ObjectPageLayout (use ObjectPageHeader instead)"
  ],
  "guidelineUrl": "https://experience.sap.com/fiori-design-web/object-header/",
