  "colorTokenRules": [
    {
      "role": "background",
      "token": "sapObjectHeader_Background",
      "fallbackHex": "#FFFFFF"
    },
    {
      "role": "border",
      "token": "sapObjectHeader_BorderColor",
      "fallbackHex": "#EAECEE"
    },
    {
      "role": "title",
      "token": "sapTitleColor",
      "fallbackHex": "#1A2733"
    }
  ],
  "accessibilityRules": [
    {
      "category": "labeling",
      "requirement": "Title is required. Intro is optional context."
    },
    {
      "category": "heading",
      "requirement": "Title renders as H2 in the document outline"
    }
  ],
  "doRules": [
    "Use in modern apps: prefer ObjectPageHeader (Object Page floorplan)",
    "Use ObjectHeader only inside a Card or Dialog when a lightweight object banner is needed"
  ],
  "dontRules": [
    "Do not use ObjectHeader as the primary page header — that's ObjectPageHeader / DynamicPageHeader",
    "Do not nest ObjectHeader inside ObjectPageLayout"
  ],
  "compatibleComponents": [
