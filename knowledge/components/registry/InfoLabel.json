    ]
  },
  "composition": {
    "validParents": ["Title","Text","Label","ObjectStatus","Panel","Card","StandardListItem","ColumnListItem","ObjectListItem","DynamicPageTitle","DynamicPageHeader","ObjectPageHeader","Toolbar","OverflowToolbar","FilterBar","Dialog","Popover","SapTableRow"],
