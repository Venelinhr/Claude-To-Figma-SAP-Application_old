    "Regular",
    "Hover",
    "Focused",
    "Disabled",
    "ReadOnly",
    "Error",
    "Warning",
    "Success",
    "Information"
  ],
  "typographyRules": [
    {
      "role": "value",
      "fontFamily": "72",
      "fontStyle": "Regular",
      "fontSize": 14,
      "sapStyleName": "MediumText/LHAuto/Regular"
    },
    {
      "role": "placeholder",
      "fontFamily": "72",
      "fontStyle": "Italic",
      "fontSize": 14,
      "sapStyleName": "MediumText/LHAuto/Italic"
    }
  ],
  "colorTokenRules": [
    {
      "role": "background",
      "token": "sapShell_Background",
      "fallbackHex": "#FFFFFF"
    },
    {
      "role": "border",
      "token": "sapField_BorderColor",
      "fallbackHex": "#556B81"
    },
    {
      "role": "text",
      "token": "sapList_TextColor",
      "fallbackHex": "#1D2D3E"
    },
    {
      "role": "text",
      "state": "placeholder",
      "token": "sapContent_LabelColor",
      "fallbackHex": "#556B82"
    }
  ],
  "accessibilityRules": [
    {
      "category": "contrast",
      "requirement": "Border contrast \u2265 3:1 against background",
      "wcag": "1.4.11"
    },
    {
      "category": "labeling",
      "requirement": "Every input MUST have a visible or aria label"
    },
    {
      "category": "focus",
      "requirement": "Visible focus indicator on focused state"
    },
    {
      "category": "status",
      "requirement": "Value state communicated by color AND icon AND text message \u2014 not color alone"
    }
  ],
  "doRules": [
    "Pair every Input with a Label component",
    "Use placeholder text only as a hint \u2014 never as a replacement for label",
    "Use valueState=Error with valueStateText message when validation fails",
    "Use type='Email' or 'Number' for semantic input types \u2014 improves mobile keyboard"
  ],
  "dontRules": [
    "Do not use placeholder as the field label",
    "Do not communicate error state by red border alone \u2014 include text",
    "Do not use Input when MultiInput, Select, or DatePicker fits better"
  ],
  "compatibleComponents": [
    "Label",
    "Form",
    "SimpleForm",
    "Toolbar",
    "Dialog"
  ],
  "incompatiblePatterns": [
    "Inside a non-form container without a Label",
    "Stacked tightly without spacing"
  ],
  "guidelineUrl": "https://experience.sap.com/fiori-design-web/input-field/",
  "demoKitUrl": "https://sapui5.hana.ondemand.com/#/entity/sap.m.Input",
  "apiUrl": "https://sapui5.hana.ondemand.com/#/api/sap.m.Input",
